# Oura Ring (OAuth) — https://cloud.ouraring.com/personal-access-tokens
OURA_CLIENT_ID=
OURA_CLIENT_SECRET=

# Whoop (OAuth) — https://developer.whoop.com
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# Chronometer (web scraper — requires CHRONO_EMAIL + CHRONO_PASS)
CHRONO_EMAIL=
CHRONO_PASS=

# Withings (OAuth) — register at developer.withings.com
WITHINGS_CLIENT_ID=
WITHINGS_CLIENT_SECRET=

# Macrofactor — no credentials needed, uses CSV export from the app

# Gemini Vision for Ladder screenshot OCR (optional, falls back to Tesseract)
GEMINI_API_KEY=
NEXT_PUBLIC_GEMINI_CONFIGURED=0
